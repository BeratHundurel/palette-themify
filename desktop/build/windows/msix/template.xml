<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="themesmith.exe"
        Arguments=""
        InstallLocation="C:\Program Files\ThemeSmith\ThemeSmith">
    </Installer>
    <PackageInformation
        PackageName="ThemeSmith"
        PackageDisplayName="ThemeSmith"
        PublisherName="CN=ThemeSmith"
        PublisherDisplayName="ThemeSmith"
        Version="0.0.1.0"
        PackageDescription="Generate editor themes from image palettes">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.themesmith.desktop"
                Description="Generate editor themes from image palettes"
                DisplayName="ThemeSmith"
                ExecutableName="themesmith.exe"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>ThemeSmith</DisplayName>
            <PublisherDisplayName>ThemeSmith</PublisherDisplayName>
            <Description>Generate editor themes from image palettes</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="themesmith.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
