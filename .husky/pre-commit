#!/usr/bin/env sh

set -e

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED_FILES" ]; then
	exit 0
fi

printf '%s\n' "$STAGED_FILES" | while IFS= read -r file; do
	case "$file" in
		frontend/*)
			case "$file" in
				*.js|*.ts|*.svelte|*.css|*.scss|*.md|*.json|*.yml|*.yaml)
					npx --prefix frontend prettier --write "$file"
					git add "$file"
					;;
			esac
			;;
		api/go/*)
			case "$file" in
				*.go)
					gofmt -w "$file"
					git add "$file"
					;;
			esac
			;;
		api/zig/*)
			case "$file" in
				*.zig)
					zig fmt "$file"
					git add "$file"
					;;
			esac
			;;
	esac
done
