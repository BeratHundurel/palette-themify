#!/usr/bin/env sh
set -e

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT" || exit 1

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED_FILES" ]; then
	exit 0
fi

FRONTEND_FILES=""
GO_FILES=""
ZIG_FILES=""

for file in $STAGED_FILES; do
	case "$file" in
		frontend/*)
			FRONTEND_FILES="$FRONTEND_FILES ${file#frontend/}"
			;;
		*.go)
			GO_FILES="$GO_FILES $file"
			;;
		*.zig)
			ZIG_FILES="$ZIG_FILES $file"
			;;
	esac
done

if [ -n "$FRONTEND_FILES" ]; then
	cd "$REPO_ROOT/frontend" || exit 1
	npm run format:staged -- $FRONTEND_FILES
	cd "$REPO_ROOT" || exit 1
fi

if [ -n "$GO_FILES" ]; then
	gofmt -w $GO_FILES
fi

if [ -n "$ZIG_FILES" ]; then
	zig fmt $ZIG_FILES
fi

git add -- $STAGED_FILES

if [ -n "$FRONTEND_FILES" ]; then
	cd "$REPO_ROOT/frontend" || exit 1
	npm test
fi
